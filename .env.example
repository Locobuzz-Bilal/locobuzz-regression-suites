# ==========================================================================
#  Locobuzz Regression Suites — environment configuration
# ==========================================================================
#  1. Copy this file to ".env" in the repo root:   cp .env.example .env
#  2. Fill in the real values below (get the test-account passwords from
#     whoever owns the test accounts — they are NOT stored in this repo).
#  3. .env is gitignored — never commit real credentials.
#
#  The suites auto-load this file from the repo root at startup; no extra
#  setup needed. Only fill in the sections for the channels you plan to run.
# ==========================================================================


# --------------------------------------------------------------------------
#  PLATFORM LOGIN CREDENTIALS (test users that log into Locobuzz)
#  Each channel suite logs in as its own test user. "_CSD" = the second
#  (CSD-environment) user for that channel where the suite needs two.
# --------------------------------------------------------------------------

# Twitter / X
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_CSD=
TWITTER_CSD_PASSWORD=
# Twitter "other-ticket" / agent user (reply-and-assign, OT flows)
TWITTER_AGENT_OT=
TWITTER_AGENT_OT_PASSWORD=

# Instagram
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_CSD=
INSTAGRAM_CSD_PASSWORD=

# Facebook
FB_USERNAME=
FB_PASSWORD=
FB_CSD=
FB_CSD_PASSWORD=

# Email channel
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_CSD=
EMAIL_CSD_PASSWORD=

# YouTube
YOUTUBE_USERNAME=
YOUTUBE_PASSWORD=

# LinkedIn
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# Super Admin (account-settings / brand / user management tests)
SA_USERNAME=
SA_PASSWORD=

# Workflow Automation user
WORKFLOW_USERNAME=
WORKFLOW_PASSWORD=


# --------------------------------------------------------------------------
#  TICKET ASSIGNMENT (reply-and-assign tests)
#  Name of the agent a ticket gets assigned to. Optional — each test has a
#  sensible default (e.g. "juw_agent" / "facebook agent"). Override here
#  only if your test accounts use a different agent name.
# --------------------------------------------------------------------------
ASSIGN_USER=


# --------------------------------------------------------------------------
#  EMAIL REPORT DELIVERY (sends the HTML report after a suite run)
#  Uses a Gmail App Password (not the account password). Leave blank to skip
#  emailing reports — the HTML report is still written locally either way.
# --------------------------------------------------------------------------
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-gmail-app-password
EMAIL_TO=recipient1@example.com,recipient2@example.com

# Recipients for the AWA (analytics) regression report (comma-separated)
AWA_EMAIL=recipient1@example.com,recipient2@example.com

# Alternate SMTP sender used by helpers/send_email.py
SMTP_EMAIL=your-email@example.com
SMTP_PASS=your-gmail-app-password


# --------------------------------------------------------------------------
#  REPORT METADATA (optional — cosmetic labels on the report)
# --------------------------------------------------------------------------
# Environment label shown on the report: CX / PreProd / UAT
REPORT_ENVIRONMENT=CX
ENVIRONMENT=CX
# "Run by" name shown on the report
REPORT_RUN_BY=Automation


# --------------------------------------------------------------------------
#  RUN BEHAVIOR (optional)
# --------------------------------------------------------------------------
# Auto-retry failed tests N times (0 = no retries)
GLOBAL_RERUNS=0
GLOBAL_RERUNS_DELAY=0
# Windows only — path to chromedriver.exe. If unset, webdriver-manager is used.
CHROMEDRIVER_PATH=

# Note: CI / GITHUB_ACTIONS / CODEBUILD_BUILD_ID are set automatically by the
# CI system to force headless mode. Do not set them for local runs.
